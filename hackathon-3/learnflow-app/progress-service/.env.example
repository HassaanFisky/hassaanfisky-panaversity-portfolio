# progress-service/.env.example
# Copy to .env and fill in real values before running locally.

# --- Required ---
# Supabase project URL (Settings → API → Project URL)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Supabase service_role key (Settings → API → service_role)
# Use service_role (not anon) so the service can bypass RLS policies.
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxxxxxxxxxx
