# triage-service/.env.example
# Copy to .env and fill in real values before running locally.

# --- Required ---
# Groq API key — get one free at https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Downstream service URLs ---
# When running all services locally, use the defaults below.
# On Koyeb, set these to the deployed public URLs for each service.
CONCEPTS_SERVICE_URL=http://localhost:8001
CODEREVIEW_SERVICE_URL=http://localhost:8002
DEBUG_SERVICE_URL=http://localhost:8003
EXERCISE_SERVICE_URL=http://localhost:8004
PROGRESS_SERVICE_URL=http://localhost:8005
